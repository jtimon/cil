mode test

test_array_dynamic_u8 := proc() {
    mut dyn := ArrayU8.new_dyn()
    test(loc(), I64.eq(dyn.len, 0), "Initial dynamic array length should be 0")
    // test(loc(), I64.eq(dyn.cap, ArrayU8.INIT_DYN_CAP), "Initial dynamic array capacity") // TODO FIX this is strange af

    dyn.push(U8.from_i64(42))
    dyn.push(U8.from_i64(255))
    test(loc(), I64.eq(dyn.len, 2), "Length after two pushes")
    test(loc(), U8.eq(dyn.get(0), U8.from_i64(42)), "Value at index 0")
    test(loc(), U8.eq(dyn.get(1), U8.from_i64(255)), "Value at index 1")

    dyn.set(0, U8.from_i64(99))
    test(loc(), U8.eq(dyn.get(0), U8.from_i64(99)), "Set and get index 0")

    dyn.delete()
    test(loc(), I64.eq(dyn.ptr, 0), "Pointer cleared after delete")
    test(loc(), I64.eq(dyn.len, 0), "Length reset after delete")
    test(loc(), I64.eq(dyn.cap, 0), "Capacity reset after delete")
}

test_array_static_u8 := proc() {
    mut stat := ArrayU8.new(3)
    test(loc(), I64.eq(stat.len, 3), "Static array len equals cap")
    test(loc(), not(stat.is_dyn), "Static array should not be dynamic")
    stat.set(0, U8.from_i64(10))
    stat.set(1, U8.from_i64(20))
    stat.set(2, U8.from_i64(30))
    test(loc(), U8.eq(stat.get(2), U8.from_i64(30)), "Get after set at index 2")

    // Uncomment to test panic behavior
    // stat.push(U8.from_i64(77)) // Should panic

    stat.delete()
}

