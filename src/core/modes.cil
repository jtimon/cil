}

Cli := func() returns ModeDef {
    mut m := ModeDef()
    m.name = "cli"
    m.allows_proc_decl = true
    m.allows_func_print = false
    m.allows_base_calls = false
    m.allows_base_mut = true
    m.allows_base_anything = true
    m.needs_main_proc = true
    m.needs_safe_calls = false
    return m
}

Test := func() returns ModeDef {
    mut m := ModeDef()
    m.name = "test"
    m.allows_proc_decl = true
    m.allows_func_print = false
    m.allows_base_calls = true
    m.allows_base_mut = true
    m.allows_base_anything = true
    m.needs_main_proc = false
    m.needs_safe_calls = false
