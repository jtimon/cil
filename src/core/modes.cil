mode pure

ModeDef := struct {
    name := "pure"
    allows_proc_decl := false
    allows_func_print := false
    allows_base_calls := false
    allows_base_mut := false
    allows_base_anything := false
    needs_main_proc := false
    needs_safe_calls := false
}

Pure := func() returns ModeDef {
    mut m := ModeDef()
    m.name = "pure"
    m.allows_proc_decl = false
    m.allows_func_print = false
    m.allows_base_calls = false
    m.allows_base_mut = false
    m.allows_base_anything = false
    m.needs_main_proc = false
    m.needs_safe_calls = false
    return m
}

Pura := func() returns ModeDef {
    mut m := ModeDef()
    m.name = "pura"
    m.allows_proc_decl = false
    m.allows_func_print = true
    m.allows_base_calls = false
    m.allows_base_mut = false
    m.allows_base_anything = false
    m.needs_main_proc = false
    m.needs_safe_calls = false
    return m
}

